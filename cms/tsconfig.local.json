{
  "compilerOptions": {
    "allowJs": true,
    "checkJs": false,
    "resolveJsonModule": true,
    "outDir": "dist",
    "rootDir": ".",
    "module": "commonjs",
    "target": "ES2020",
    "skipLibCheck": true
  },
  "include": [
    "config/**/*.js",
    "scripts/.strapi-json-manifest.local.ts",
    "src/**/*.js",
    "types/**/*.d.ts"
  ],
  "exclude": [
    "build",
    "dist",
    "node_modules"
  ]
}
